# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend S3 proxy config
# This is the S3 key prefix where your React build is uploaded.
# e.g. if your build files are at s3://your-bucket/frontend/index.html
# then set this to: frontend
FRONTEND_S3_PREFIX=frontend

# AWS S3 Configuration (uses ECS task role in production — no keys needed)
AWS_REGION=ap-south-1
S3_BUCKET_NAME=afl-legalaudit

# Redis / BullMQ (ElastiCache URL injected via Secrets Manager in production)
# REDIS_URL=redis://your-elasticache-endpoint:6379

# Anthropic Claude API (injected via Secrets Manager in production)
# ANTHROPIC_API_KEY=sk-ant-api...

# Super Admin Email
SUPER_ADMIN_EMAIL=nilesh@acc.com

# Local dev only — not used in production (same-origin via ALB)
FRONTEND_URL=http://localhost:3000
